.stat-card {
     background: rgba(46, 125, 50, 0.85); 
    padding: 25px;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-top: 4px solid #2e7d32; 
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
}

        .stat-number { font-size: 40px; font-weight: 800; color: lightgrey; }
        .stat-label { color: white; font-size: 24px; text-transform: uppercase; }

        .btn-primary {
           background: linear-gradient(to right, #2E7D32, #FFC107, #2E7D32);
            color: white;
            border: none;
            padding: 12px 25px;
            cursor: pointer;
            font-weight: 600;
            margin-bottom: 25px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        /* --- TABLE STYLES --- */
        .applications-section {
            background: white;
            border: 1px solid #e0e0e0;
        }

        .section-header {
            padding: 15px 20px;
            background: #f8f9fa;
            border-bottom: 2px solid #e8f5e9;
            font-weight: 700;
            color: #2e7d32;
        }

        /* HORIZONTAL SCROLL FIX */
        .table-wrapper {
            width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        .grid-view {
            width: 100%;
            border-collapse: collapse;
            min-width: 850px; /* Ensures scroll triggers on mobile */
        }

        .grid-view th { background: #f8f9fa; padding: 15px; text-align: left; border-bottom: 2px solid #dee2e6; white-space: nowrap; }
        .grid-view td { padding: 15px; border-bottom: 1px solid #eee; white-space: nowrap; }

        /* --- MOBILE RESPONSIVE (CRITICAL UPDATES) --- */
        @media (max-width: 768px) {
            .navbar { padding: 10px 20px; }
            .container {
                flex-direction: column;
                margin-top: 60px;
            }

            .sidebar {
                position: relative;
                width: 100%;
                height: auto;
                top: 0;
                left: 0;
                display: flex;
                overflow-x: auto; 
                padding: 0;
                margin-top: 20px; 
                border-right: none;
                border-bottom: 1px solid #e0e0e0;
                background: #fff;
            }

            .nav-item {
                padding: 12px 20px;
                white-space: nowrap;
                border-left: none;
                border-bottom: 3px solid transparent;
            }

            .nav-item.active {
                border-bottom: 3px solid #2e7d32;
                background: #e8f5e9;
            }

            .main-content {
                margin-left: 0; 
                padding: 20px 15px;
            }

            .grid-view {
                min-width: 1000px; 
            }
        }
    </style>
