        .nav-item:hover, .nav-item.active {
            background: #e8f5e9;
            border-left: 4px solid #2e7d32;
            color: #2e7d32;
        }

        .main-content {
            flex: 1;
            margin-left: 260px; /* Leave space for sidebar */
